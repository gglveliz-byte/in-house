# ===========================================
# IN HOUSE DELIVERY - Variables de Entorno
# ===========================================
# Copia este archivo como .env y completa los valores

# ============ BASE DE DATOS ============
# PostgreSQL (Render, Railway, Supabase, etc.)
DATABASE_URL="postgresql://usuario:contraseña@host:5432/nombre_db?schema=public"

# ============ AUTENTICACIÓN ============
# NextAuth.js - Genera con: openssl rand -base64 32
NEXTAUTH_SECRET="tu-clave-secreta-muy-larga-aqui"
NEXTAUTH_URL="https://tudominio.com"

# ============ TIEMPO REAL ============
# Pusher Channels (https://pusher.com)
PUSHER_APP_ID="tu_app_id"
PUSHER_KEY="tu_key"
PUSHER_SECRET="tu_secret"
PUSHER_CLUSTER="us2"

# Variables públicas de Pusher (accesibles desde el cliente)
NEXT_PUBLIC_PUSHER_KEY="tu_key"
NEXT_PUBLIC_PUSHER_CLUSTER="us2"

# ============ ALMACENAMIENTO DE IMÁGENES ============
# Cloudinary (https://cloudinary.com)
CLOUDINARY_CLOUD_NAME="tu_cloud_name"
CLOUDINARY_API_KEY="tu_api_key"
CLOUDINARY_API_SECRET="tu_api_secret"

# ============ MAPAS ============
# Google Maps Platform (https://console.cloud.google.com)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="tu_api_key"

# ============ FIREBASE ============
NEXT_PUBLIC_FIREBASE_API_KEY="tu_api_key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="tu_proyecto.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="tu_proyecto"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="tu_proyecto.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="tu_messaging_sender_id"
NEXT_PUBLIC_FIREBASE_APP_ID="tu_app_id"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="tu_measurement_id"

# ============ EMAIL (Recuperación de contraseña) ============
# Gmail SMTP (habilitar "App Passwords" en Google)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="tu_correo@gmail.com"
SMTP_PASS="tu_app_password"
