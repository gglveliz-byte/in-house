generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Zona geográfica (administrada por un Admin)
model Zone {
  id            String    @id @default(cuid())
  name          String
  description   String?
  latitude      Float
  longitude     Float
  radius        Float     @default(10)
  currency      String    @default("USD")
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  admins        User[]    @relation("ZoneAdmins")
  stores        Store[]
  orders        Order[]
}

// Usuario del sistema (super_admin, admin, vendedor, repartidor)
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  role          String    @default("VENDOR")
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  registeredAt  DateTime?

  zoneId        String?
  zone          Zone?     @relation("ZoneAdmins", fields: [zoneId], references: [id])

  superAdminId  String?
  superAdmin    User?     @relation("SuperAdminAdmins", fields: [superAdminId], references: [id])
  managedAdmins User[]    @relation("SuperAdminAdmins")

  createdByAdminId String?
  createdByAdmin   User?   @relation("AdminCreatesUsers", fields: [createdByAdminId], references: [id])
  createdUsers     User[]  @relation("AdminCreatesUsers")

  stores        Store[]   @relation("StoreOwner")
  deliveries    Order[]   @relation("DriverOrders")

  sentMessages     AdminMessage[] @relation("MessageSender")
  receivedMessages AdminMessage[] @relation("MessageReceiver")
  notifications    Notification[]

  billingCycles  BillingCycle[]
  passwordResets PasswordReset[]

  @@index([role])
  @@index([zoneId])
  @@index([superAdminId])
  @@index([createdByAdminId])
}

// Tienda
model Store {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  description   String?
  logo          String?
  banner        String?
  whatsapp      String
  address       String
  latitude      Float?
  longitude     Float?
  isOpen        Boolean   @default(true)
  minOrder      Float     @default(0)
  deliveryFee   Float     @default(0)
  minDeliveryFee Float    @default(0)
  maxDeliveryFee Float    @default(0)
  paymentMethods String?
  businessHours String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  ownerId       String
  owner         User      @relation("StoreOwner", fields: [ownerId], references: [id])

  zoneId        String?
  zone          Zone?     @relation(fields: [zoneId], references: [id])

  products      Product[]
  orders        Order[]
  categories    Category[]

  @@index([zoneId])
  @@index([ownerId])
}

// Categoría de productos
model Category {
  id            String    @id @default(cuid())
  name          String
  order         Int       @default(0)

  storeId       String
  store         Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products      Product[]

  @@index([storeId])
}

// Producto
model Product {
  id            String    @id @default(cuid())
  name          String
  description   String?
  price         Float
  image         String?
  isAvailable   Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  storeId       String
  store         Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  categoryId    String?
  category      Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems    OrderItem[]

  @@index([storeId])
  @@index([storeId, isAvailable])
}

// Contador global para números de pedido
model Counter {
  id            String    @id @default("order_counter")
  value         Int       @default(1000)
}

// Pedido
model Order {
  id              String    @id @default(cuid())
  orderNumber     Int
  status          String    @default("PENDING")

  customerName    String
  customerPhone   String
  customerAddress String
  customerLat     Float?
  customerLng     Float?
  customerNotes   String?

  subtotal        Float
  deliveryFee     Float     @default(0)
  actualDeliveryFee Float?
  total           Float

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  confirmedAt     DateTime?
  readyAt         DateTime?
  pickedUpAt      DateTime?
  deliveredAt     DateTime?

  paymentMethod   String    @default("CASH")
  paymentStatus   String    @default("PENDING")
  paymentProof    String?

  deliveryPaymentStatus String?
  deliveryPaymentProof  String?

  storeId         String
  store           Store     @relation(fields: [storeId], references: [id])
  driverId        String?
  driver          User?     @relation("DriverOrders", fields: [driverId], references: [id])

  zoneId          String?
  zone            Zone?     @relation(fields: [zoneId], references: [id])

  items           OrderItem[]
  messages        Message[]

  @@index([status])
  @@index([storeId])
  @@index([zoneId])
  @@index([driverId])
  @@index([createdAt])
  @@index([status, storeId])
  @@index([deliveredAt])
}

// Items del pedido
model OrderItem {
  id            String    @id @default(cuid())
  quantity      Int
  unitPrice     Float
  totalPrice    Float
  notes         String?

  orderId       String
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String
  product       Product   @relation(fields: [productId], references: [id])

  @@index([orderId])
}

// Mensajes del chat de pedidos
model Message {
  id            String    @id @default(cuid())
  content       String
  imageUrl      String?
  senderType    String
  senderName    String
  isRead        Boolean   @default(false)
  createdAt     DateTime  @default(now())

  orderId       String
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// Ciclo de facturación mensual (para Admins)
model BillingCycle {
  id            String    @id @default(cuid())

  startDate     DateTime
  endDate       DateTime

  totalOrders   Int       @default(0)
  totalDeliveryRevenue Float @default(0)

  amountDue     Float     @default(10)
  isPaid        Boolean   @default(false)
  paidAt        DateTime?
  paymentProof  String?

  status        String    @default("ACTIVE")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  adminId       String
  admin         User      @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([startDate, endDate])
}

// Mensajes entre Super Admin y Admin
model AdminMessage {
  id            String    @id @default(cuid())
  content       String
  imageUrl      String?
  messageType   String    @default("GENERAL")
  isRead        Boolean   @default(false)
  createdAt     DateTime  @default(now())

  senderId      String
  sender        User      @relation("MessageSender", fields: [senderId], references: [id])
  receiverId    String
  receiver      User      @relation("MessageReceiver", fields: [receiverId], references: [id])

  billingCycleId String?

  @@index([senderId, receiverId])
}

// Token de recuperación de contraseña
model PasswordReset {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// Notificaciones
model Notification {
  id            String    @id @default(cuid())
  title         String
  message       String
  type          String    @default("INFO")
  isRead        Boolean   @default(false)
  link          String?
  createdAt     DateTime  @default(now())

  userId        String
  user          User      @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
}
